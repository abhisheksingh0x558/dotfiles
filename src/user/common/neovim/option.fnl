{:g {;;; Code style
     ;; Editorconfig integration
     :editorconfig true
     ;;; Keymaps
     :mapleader " "
     :maplocalleader "\\"}
 ;;; UI/UX
 ;; Line numbering
 :number true
 ;; System clipboard
 :clipboard :unnamedplus
 ;; Smart seach
 :ignorecase true
 :smartcase true
 ;; Window layout manager
 :splitright true
 :splitbelow true}
