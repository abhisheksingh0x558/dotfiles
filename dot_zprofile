# -*- mode: sh -*-
# vim: filetype=zsh

# Version manager
source <(mise activate zsh --shims)

# Path
path+="${$(go env GOBIN):-$(go env GOPATH)/bin}" # Global Go binaries

# Key manager
ssh_keys=(
	~/.ssh/default/auth_git_forge # Default git forge
)
for key in "${ssh_keys[@]}"; do
	[[ -f $key ]] && eval "$(keychain --eval --quiet "$key")"
done
unset ssh_keys
