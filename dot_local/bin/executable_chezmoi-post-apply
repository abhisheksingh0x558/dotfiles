#!/usr/bin/env nu

# Install Dot CLI
cargo install --path ~/.local/share/dot

# GnuPG UI/UX
do {
	let gpg_dir = ($nu.home-path | path join '.gnupg')
	if not ($gpg_dir | path exists) {
		mkdir $gpg_dir
		chmod 700 $gpg_dir
	}
	let gpg_file = ($gpg_dir | path join 'gpg-agent.conf')
	if not ($gpg_file | path exists) and (uname | get kernel-name) == "Darwin" {
		echo $'pinentry-program (which pinentry-mac | get 0.path)' | save --force $gpg_file
	}
}
